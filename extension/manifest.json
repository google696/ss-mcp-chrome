{
  "manifest_version": 3,
  "name": "SS MCP Chrome",
  "version": "0.1.0",
  "key": "",
  "minimum_chrome_version": "135",
  "description": "将 Chrome 连接到 ss-mcp-chrome 本地 MCP 桥接服务。",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "userScripts",
    "sidePanel",
    "downloads",
    "nativeMessaging",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "SS MCP Chrome",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options.html"
}
